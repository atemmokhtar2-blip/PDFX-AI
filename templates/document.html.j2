<!DOCTYPE html>
<html lang="{{ 'ar' if plan.language != 'en' else 'en' }}" dir="{{ plan.direction }}">
<head>
<meta charset="UTF-8">
<title>{{ plan.title }}</title>
<style>
{% include "style.css.j2" %}
</style>
</head>
<body class="tone-{{ design.tone }} heading-{{ design.heading_style }} density-{{ design.density }} {{ 'rounded' if design.rounded else 'sharp' }} motif-{{ design.motif }}">

{% if plan.needs_cover %}
<section class="cover cover-{{ design.cover_variant }}">
  <div class="cover-decor-a"></div>
  <div class="cover-decor-b"></div>
  <div class="cover-decor-c"></div>
  <div class="cover-body">
    <div class="cover-kicker">PDFX&nbsp;AI</div>
    <h1 class="cover-title">{{ plan.title }}</h1>
    {% if plan.subtitle %}<p class="cover-subtitle">{{ plan.subtitle }}</p>{% endif %}
    <div class="cover-meta">
      {% if plan.author %}<div>{{ plan.author }}</div>{% endif %}
      {% if plan.date %}<div>{{ plan.date }}</div>{% endif %}
    </div>
  </div>
  <div class="cover-footer">
    <span class="doc-type-badge">{{ doc_type_label }}</span>
  </div>
</section>
{% endif %}

{% if plan.needs_toc %}
<section class="toc-page">
  <h1 class="toc-heading">{{ 'الفهرس' if plan.direction == 'rtl' else 'Table of Contents' }}</h1>
  <nav class="toc toc-{{ design.toc_style }}">
    {% for h in headings %}
    <div class="toc-line toc-level-{{ h.level }}">
      {% if design.toc_style == 'numbered-chips' %}<span class="toc-chip">{{ loop.index }}</span>{% endif %}
      <a href="#{{ h.id }}">{{ h.text }}</a>
    </div>
    {% endfor %}
  </nav>
</section>
{% endif %}

<section class="content">
  {% if not plan.needs_cover %}
  <header class="inline-title">
    <div class="inline-kicker">PDFX&nbsp;AI</div>
    <h1>{{ plan.title }}</h1>
    {% if plan.subtitle %}<p class="inline-subtitle">{{ plan.subtitle }}</p>{% endif %}
  </header>
  {% endif %}
  {{ body_html }}
</section>

</body>
</html>
